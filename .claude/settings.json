{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(./**)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(pwsh -NoProfile -Command Get-Module*)",
      "Bash(pwsh -NoProfile -Command Get-Verb*)",
      "Bash(pwsh -NoProfile -Command Invoke-ScriptAnalyzer*)",
      "Bash(pwsh -NoProfile -Command Invoke-Pester*)"
    ],
    "ask": [
      "Write(./**)",
      "Edit(./**)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(npm install *)",
      "Bash(pip install *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./.git/config)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.npmrc)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | *sh*)",
      "Bash(wget * | *sh*)",
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(npm publish *)",
      "Bash(gh release *)",
      "Bash(gh repo delete *)"
    ]
  }
}
